rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function getRole(uid) {
      return get(/databases/$(database)/documents/users_metadata/$(uid)).data.role;
    }
    function isAdmin() {
      return isMaster()
        || getRole(request.auth.uid) == 'sales_manager'
        || getRole(request.auth.uid) == 'gerencia'
        || getRole(request.auth.uid) == 'director'
        || getRole(request.auth.uid) == 'administrador';
    }
    function isAdministrador() {
      return getRole(request.auth.uid) == 'administrador';
    }
    function isMaster() {
      // El máster puede ser la cuenta-correo original O cualquier usuario con
      // rol 'master' en users_metadata (Etapa 2). getRole() lee el mismo doc que
      // ya consultan isAdmin()/getRole() en la misma evaluación (cacheado), y el
      // check de correo va primero (corto-circuito) para no leer de más.
      return isAuthenticated()
        && (request.auth.token.email == 'lacteoca@lacteoca.com'
            || getRole(request.auth.uid) == 'master');
    }
    function isKromaMaster() {
      return isMaster() || getRole(request.auth.uid) == 'master';
    }
    function isMerchandiser() {
      return getRole(request.auth.uid) == 'merchandiser';
    }
    function isVendedor() {
      return getRole(request.auth.uid) == 'vendedor';
    }
    function isComercialAccess() {
      return isAdmin() || isMaster() || isVendedor();
    }
    function isProduccion() {
      return getRole(request.auth.uid) == 'produccion';
    }
    function isAuthenticated() {
      return request.auth != null;
    }
    function isKromaAccess() {
      return isKromaMaster()
        || getRole(request.auth.uid) == 'produccion'
        || getRole(request.auth.uid) == 'kroma_admin'
        || getRole(request.auth.uid) == 'kroma_gerencial'
        || getRole(request.auth.uid) == 'kroma_operario';
    }
    function isKromaAdmin() {
      return isKromaMaster() || getRole(request.auth.uid) == 'kroma_admin';
    }

    match /users_metadata/{userId} {
      allow get: if isAuthenticated() && (request.auth.uid == userId || isAdmin() || isMaster());
      allow list: if isAdmin() || isMaster();
      allow write: if request.auth.uid == userId || isMaster();
      match /authenticators/{authenticatorId} {
        allow read, write: if request.auth.uid == userId;
      }
      match /tokens/{tokenId} {
        allow read, create, delete: if request.auth.uid == userId;
      }
    }

    match /login_index/{key} {
      // Índice público usuario→correo para permitir login por NOMBRE DE USUARIO
      // (se resuelve el correo antes de autenticar). Solo expone el correo, no
      // datos sensibles. Lo escribe el master al crear/editar usuarios.
      allow get: if true;
      allow list: if false;
      allow create, update, delete: if isMaster();
    }

    match /reporters/{reporterId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /visit_reports/{reportId} {
      allow get: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow list: if isAdmin() || getRole(request.auth.uid) == 'vendedor' || (isMerchandiser() && resource.data.userId == request.auth.uid);
      allow create: if (isMerchandiser() || isAdmin()) && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isMaster();
    }

    match /delegated_tasks/{taskId} {
      allow list: if isAuthenticated() && (isAdmin() || isMerchandiser());
      allow get, update: if isAuthenticated() && (isAdmin() || isMerchandiser());
      allow create: if isAdmin();
      allow delete: if isMaster();
    }

    match /delegation_invites/{inviteId} {
      allow get: if isAuthenticated();
      allow write: if false;
    }

    match /ajustes_pendientes/{ajusteId} {
      allow get: if isAuthenticated() && (request.auth.uid == resource.data.requesterId || isAdmin());
      allow list: if isAdmin();
      allow create: if isAdmin() || isProduccion();
      allow update: if isMaster();
      allow delete: if false;
    }

    match /pagos_registrados/{pagoId} {
      // Admin gestiona todo. El vendedor puede leer sus propios pagos
      // (comisión de la semana en GK → VendedorLayout) comparando el
      // reporterId del pago con el reporterId configurado en su perfil.
      allow read: if isAdmin() || (
        isVendedor() &&
        resource.data.reporterId == get(/databases/$(database)/documents/users_metadata/$(request.auth.uid)).data.reporterId
      );
      allow write: if isAdmin();
      allow delete: if false;
    }

    match /facturas_vendedor/{facturaId} {
      // Sincronizadas desde Zoho (Administración → Integraciones). Cada
      // vendedor ve solo sus propias facturas; admin/master gestionan todas.
      allow get, list: if isAuthenticated() && (isAdmin() || isMaster() || resource.data.vendedorId == request.auth.uid);
      allow write: if isAdmin() || isMaster();
    }

    match /comisiones_mensuales/{mesId} {
      // Acumulado por mes de CALENDARIO (gerente / Rendimiento Comercial),
      // escrito por sincronizarFacturaDesdeZoho. Cada vendedor lee solo su
      // propio acumulado; admin/master leen todos.
      allow get, list: if isAuthenticated() && (isAdmin() || isMaster() || resource.data.vendedorId == request.auth.uid);
      allow write: if isAdmin() || isMaster();
    }

    match /comisiones_periodos/{periodoId} {
      // Acumulado por PERÍODO DE EMPLEO del vendedor (mes 15→14, Fase 3.5):
      // define su tasa-cohorte y su Estado de Cuenta. Mismo patrón de acceso.
      allow get, list: if isAuthenticated() && (isAdmin() || isMaster() || resource.data.vendedorId == request.auth.uid);
      allow write: if isAdmin() || isMaster();
    }

    match /zoho_customer_map/{key} {
      // Mapa razón social (customer_name de Zoho) → vendedor (Fase 3.3).
      // Lo escribe la Cloud Function vincularRazonSocial (Admin SDK); desde el
      // cliente solo se lee para mostrar la herramienta de vinculación.
      allow get, list: if isAuthenticated() && (isAdmin() || isMaster());
      allow write: if isAdmin() || isMaster();
    }

    match /facturas_bloqueadas/{numero} {
      // Tombstone de facturas eliminadas/anuladas por admin: el webhook (Admin
      // SDK) las consulta para NO resucitarlas. Escritura solo vía Cloud Function.
      allow get, list: if isAdmin() || isMaster();
      allow write: if false;
    }

    match /comisiones_cerradas/{cierreId} {
      // Snapshot congelado del devengado de un período de empleo cerrado (Fase
      // 3.10). El vendedor lee los suyos; admin/master leen y congelan; master o
      // administrador reabren (borran) — el administrador es quien congela.
      allow get, list: if isAuthenticated() && (isAdmin() || isMaster() || resource.data.vendedorId == request.auth.uid);
      allow create, update: if isAdmin() || isMaster();
      allow delete: if isMaster() || isAdministrador();
    }

    match /liquidaciones/{liqId} {
      // Pagos de comisión al vendedor (Fase 3.8). El vendedor lee solo los
      // suyos (Estado de Cuenta: devengado/pagado/saldo); admin/master leen y
      // registran todos. El administrador (operativo) y el master pueden borrar
      // para corregir un pago mal cargado.
      allow get, list: if isAuthenticated() && (isAdmin() || isMaster() || resource.data.vendedorId == request.auth.uid);
      allow create, update: if isAdmin() || isMaster();
      allow delete: if isMaster() || isAdministrador();
    }

    // Comprobante de pago del banco adjunto a una liquidación (imagen en data URL,
    // doc aparte para no inflar la liquidación). Mismo acceso que liquidaciones.
    match /liquidacion_comprobantes/{liqId} {
      allow get, list: if isAuthenticated() && (isAdmin() || isMaster() || resource.data.vendedorId == request.auth.uid);
      allow create, update: if isAdmin() || isMaster();
      allow delete: if isMaster() || isAdministrador();
    }

    match /pos/{posId} {
      allow get, list: if isAuthenticated();
      allow create: if isMaster() || isAdmin() || isMerchandiser();
      allow update: if isAuthenticated() && (
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['coordinates', 'gpsStatus'])
        || isMaster()
        || (isAdmin() && resource.data.gpsStatus != 'verified')
        || resource.data.gpsStatus == 'pending'
        || resource.data.gpsStatus == 'provisional'
      );
      allow delete: if isMaster();
    }

    match /competitors/{competitorId} {
      allow get, list: if isAuthenticated();
      allow create, update: if isAdmin() || isMaster();
      allow delete: if isMaster();
    }

    match /depots/{depotId} {
      allow get, list: if isAuthenticated() && (isProduccion() || isAdmin() || isMerchandiser());
      allow write: if isProduccion() || isAdmin();
      match /stock/{productId} {
        allow get, list: if isAuthenticated() && (isProduccion() || isAdmin());
        allow write: if isProduccion() || isAdmin();
      }
    }

    match /ventas_pendientes/{saleId} {
      allow read, write, update: if isAdmin();
    }

    match /movimientos_inventario/{movimientoId} {
      allow get, list: if isAdmin();
      allow create, update, delete: if false;
    }

    match /transfers/{transferId} {
      allow get, list: if isAuthenticated();
      allow create: if isProduccion() || isAdmin();
      allow update: if isMerchandiser() || isAdmin();
      allow delete: if isMaster();
    }

    match /agendas/{reporterId} {
      allow get: if isAuthenticated() && (isAdmin() || isMerchandiser());
      match /weekly_agendas/{weekId} {
        allow list, get, write: if isAuthenticated() && (isAdmin() || isMerchandiser());
      }
    }

    match /pdv_assignments/{pdvId} {
      allow read: if isAuthenticated() && (isAdmin() || isMerchandiser());
      allow write: if false;
    }

    match /vendor_clients/{docId} {
      // Vendor reads their own portfolio; admin manages all. Merchandisers
      // also need read access to resolve which vendedor covers a PDV when
      // taking a verbal pedido (TomarPedidoForm → findVendedorForPos).
      allow read: if isAuthenticated() && (
        isAdmin() ||
        isMaster() ||
        isMerchandiser() ||
        resource.data.vendedorId == request.auth.uid
      );
      allow create: if isAuthenticated() && (
        isAdmin() ||
        isMaster() ||
        request.resource.data.vendedorId == request.auth.uid
      );
      allow update: if isAuthenticated() && (isAdmin() || isMaster());
      allow delete: if false;
    }

    match /vendedor_alertas/{docId} {
      allow read: if isAuthenticated() && (
        isAdmin() || isMaster() || resource.data.uid == request.auth.uid
      );
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (
        isAdmin() || isMaster() || resource.data.uid == request.auth.uid
      );
    }



    match /delegation_requests/{requestId} {
      allow read, write: if isAuthenticated() && (isAdmin() || isMerchandiser());
    }

    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Credenciales de la API de Zoho Books (OAuth self-client). SOLO el Admin SDK
    // (Cloud Functions) las lee/escribe — nunca el cliente. Se guardan con la
    // callable `guardarCredencialesZoho` (master) y las usa la conciliación.
    match /zoho_secure/{docId} {
      allow read, write: if false;
    }

    match /notifications/{notificationId} {
      allow read, update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // Mercaderistas notifican a gerencia/admin sobre nuevos entrantes detectados
      // en visita (VisitReportForm). Sin esta regla, el addDoc fallaba con
      // permission-denied y abortaba toda la confirmación del reporte de visita,
      // provocando reportes duplicados (ver useOfflineSync).
      allow create: if isMerchandiser() || isAdmin();
      allow delete: if isMaster();
    }

    match /pedidos/{pedidoId} {
      allow create: if isMerchandiser() || isAdmin();
      allow read: if isAdmin();
      allow update, delete: if isMaster();
    }

    match /pedidos_mercaderista/{pedidoId} {
      // Pedidos verbales: creados por mercaderistas (TomarPedidoForm) o por
      // el propio vendedor (Tomar Pedido en GK). El vendedor asignado los
      // ve y confirma/rechaza en su pestaña "Pedidos" (MisPedidosView).
      allow get, list: if isAuthenticated() && (
        isAdmin() || isMaster() || resource.data.vendedorId == request.auth.uid
      );
      allow create: if isAuthenticated() && (isMerchandiser() || isVendedor() || isAdmin());
      allow update: if isAuthenticated() && (
        isAdmin() || isMaster() || resource.data.vendedorId == request.auth.uid
      );
      allow delete: if isMaster();
    }

    match /despachos/{despachoId} {
      // Created by merchandisers/vendedores (PedidoForm); read by admin
      // dashboards and by vendedores for their own portfolio (query filters
      // by reporterId).
      allow create: if isMerchandiser() || isAdmin() || isVendedor();
      allow read:   if isAdmin() || isMerchandiser() || isVendedor();
      allow update, delete: if isMaster();
    }

    // ── Almacén Comercial (puente Kroma → GK) ──────────────────────────────
    // Inventario de los depósitos comerciales (ej. "Depósito Comercial
    // Caracas"). La CONFIGURACIÓN de almacenes (almacenes_comerciales) es
    // exclusiva de GK. El INVENTARIO (inventario_comercial) lo escribe tanto GK
    // (recepción/ajuste manual) como Kroma: al marcar un despacho como
    // entregado en Caracas, el operario de despacho sincroniza el stock
    // recibido — escritura legítima del puente Kroma → GK.
    match /almacenes_comerciales/{almacenId} {
      allow read:  if isAuthenticated() && (isKromaAccess() || isComercialAccess());
      allow write: if isAuthenticated() && isComercialAccess();
    }
    match /inventario_comercial/{itemId} {
      allow read:  if isAuthenticated() && (isKromaAccess() || isComercialAccess());
      allow write: if isAuthenticated() && (isKromaAccess() || isComercialAccess());
    }

    match /kroma_settings/{docId} {
      allow read, write: if isKromaAccess();
    }
    match /kroma_fixed_costs/{mesId} {
      allow read, write: if isKromaAccess();
    }
    match /kroma_users/{userId} {
      allow read, write: if isKromaAccess();
    }
    match /kroma_products/{id} {
      allow read, write: if isKromaAccess();
    }
    match /kroma_warehouses/{id} {
      allow read, write: if isKromaAccess();
    }
    match /kroma_suppliers/{id} {
      allow read, write: if isKromaAccess();
    }
    match /kroma_materials/{id} {
      allow read, write: if isKromaAccess();
    }
    match /kroma_recipes/{id} {
      allow read, write: if isKromaAccess();
    }
    match /kroma_processes/{id} {
      allow read, write: if isKromaAccess();
    }
    match /kroma_fichas/{id} {
      allow read, write: if isKromaAccess();
    }
    match /kroma_production_logs/{id} {
      allow read, write: if isKromaAccess();
    }
    match /kroma_milk_reception/{id} {
      allow read:   if isKromaAccess();
      allow create: if isKromaAccess();
      allow update: if isKromaAccess();
      allow delete: if isKromaAdmin();
    }
    match /kroma_inventory_materials/{id} {
      allow read, write: if isKromaAccess();
    }
    match /kroma_alerts/{id} {
      allow read: if isKromaAccess();
      allow create: if isKromaAccess();
      allow update: if isKromaAccess();
      allow delete: if isKromaMaster();
    }
    match /kroma_inventory_pt/{id} {
      allow read, write: if isKromaAccess();
    }
    match /kroma_warehouse_movements/{id} {
      allow read, write: if isKromaAccess();
    }
    match /kroma_notifications/{id} {
      allow read, write: if isKromaAccess();
    }
    match /kroma_despachos/{id} {
      // Kroma crea y gestiona despachos. GK (vendedor/gerencia/master) puede
      // leerlos y marcarlos como recibidos al ingresarlos al almacén comercial.
      allow read:           if isKromaAccess() || isComercialAccess();
      allow update:         if isKromaAccess() || isComercialAccess();
      allow create, delete: if isKromaAccess();
    }
    match /kroma_edit_requests/{id} {
      allow read, write: if isKromaAccess();
    }
    match /kroma_config/{id} {
      allow read: if isKromaAccess();
      allow write: if isKromaMaster();
    }
  }
}
